{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kodama",
  "version": "1.0.0-alpha.9",
  "identifier": "dev.kodama.music",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1421",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Kodama",
        "width": 1100,
        "height": 700,
        "minWidth": 960,
        "minHeight": 560,
        "fullscreen": false,
        "resizable": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; connect-src 'self' ipc: http://ipc.localhost http://localhost:9847 http://127.0.0.1:9847 http://127.0.0.1:8888 https://translate.googleapis.com https://api.github.com https://raw.githubusercontent.com; img-src 'self' data: https: http: blob:; media-src 'self' file: blob: https:; font-src 'self' tauri: data: https://fonts.gstatic.com; frame-src http://localhost:*"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJFQjUzNzM1QzBDRTJCRjYKUldUMks4N0FOVGUxdml4eE1YWnVqTVNkd1MvUVlQeDVmOVdXSEpkQ21QOWtHM2hDR2JwTkw5Q24K",
      "endpoints": [
        "https://raw.githubusercontent.com/KiyoshiTheDevil/Kodama-dist/master/updates/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/kodama-server"
    ]
  }
}
